<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NestJs MVC</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <h1><%= titulo %></h1>
    <h2>NestJs MVC + EJS <%= horaAgora %></h2>

    <ol>
        <% for( let index = 0; index < listaPessoas.length; index++ ) { %>
            <li><%= listaPessoas[index].nome%>: <%= listaPessoas[index].email%></li>

        <% } %>
    </ol>
    
    <table border="1">
        <tr> 
            <th>Nome</th>                          
             <th>E-mail</th>
         </tr>   

            <% for( let index = 0; index < listaPessoas.length; index++ ) { %>
               
                <tr> 
                    <td><%= listaPessoas[index].nome%></td>                          
                    <td><%= listaPessoas[index].email%></td>
                </tr>
            <% } %>
    </table>

    <a href="/contato">
        <button>Contate-me!</button>
    </a>


</body>
</html>
